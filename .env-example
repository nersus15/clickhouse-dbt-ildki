# Contoh environment variable untuk menjalankan dbt project ini secara lokal.
# Copy jadi .env dan isi sesuai environment Anda (jangan commit file .env asli).

CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=peerdb
CLICKHOUSE_PASSWORD=
# Database tujuan (layer silver) -- pastikan sudah dibuat & user di atas punya akses CREATE/DROP VIEW ke sini
CLICKHOUSE_DATABASE=silver
CLICKHOUSE_SECURE=false
CLICKHOUSE_VERIFY=false
CLICKHOUSE_CONNECT_TIMEOUT=30
